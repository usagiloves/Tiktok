# ============================================
# App
# ============================================
APP_ENV=development
APP_PORT=3000
APP_BASE_URL=http://localhost:3000
APP_TIMEZONE=Asia/Ho_Chi_Minh

# ============================================
# Database (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tiktok_lark_sync?schema=public

# ============================================
# Redis
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# TikTok Shop
# ============================================
TIKTOK_APP_KEY=your_app_key
TIKTOK_APP_SECRET=your_app_secret
TIKTOK_WEBHOOK_SECRET=your_webhook_secret
TIKTOK_REDIRECT_URI=http://localhost:3000/tiktok/oauth/callback

# ============================================
# Lark
# ============================================
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=your_lark_app_secret
LARK_BASE_APP_TOKEN=your_lark_base_app_token
LARK_TABLE_ID_CSKH=tbl_xxx
LARK_BOT_WEBHOOK_URL=https://open.larksuite.com/open-apis/bot/v2/hook/xxx

# ============================================
# Security
# ============================================
OAUTH_STATE_SECRET=your_random_secret_for_state
TOKEN_ENCRYPTION_KEY=your_32_char_encryption_key_here

# ============================================
# Monitoring (optional)
# ============================================
SENTRY_DSN=
